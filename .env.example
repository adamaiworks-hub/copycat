# ─── CopyCat Discord Agent ────────────────────────────────────────────────────
# Copy this to .env and fill in your values

# Discord bot token (discord.com/developers → Your App → Bot → Token)
DISCORD_BOT_TOKEN=your_bot_token_here

# Your Discord server ID (right-click server name → Copy Server ID)
DISCORD_GUILD_ID=your_guild_id_here

# Channel IDs — right-click each channel → Copy Channel ID
DISCORD_CH_ALERTS_ALL=
DISCORD_CH_ALERTS_CRYPTO=
DISCORD_CH_ALERTS_POLITICS=
DISCORD_CH_ALERTS_SPORTS=
DISCORD_CH_ALERTS_ECONOMICS=
DISCORD_CH_GENERAL=
DISCORD_CH_ANNOUNCEMENTS=
DISCORD_CH_LEADERBOARD=

# Timing
MORNING_BRIEF_HOUR=8
ALERT_POLL_MINS=30
